includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    level: 6

    paths:
        - app/
        - bootstrap/
        - config/
        - lang/
        - database/
        - public/
        - resources/
        - routes/
        - tests/

    reportUnmatchedIgnoredErrors: true
    treatPhpDocTypesAsCertain: false

    ignoreErrors:
